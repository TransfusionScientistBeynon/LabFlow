    <input type ="button" value="Sample received" id="$\{item.requestId\}" class="sampleReceivedButton"> \par
    <input type="button" value="In progress" id="$\{item.requestId\}" class="sampleInProgressButton">\par
    <input type="button" value="Completed" class="requestCompleteButton" id="$\{item.requestId\}"> \par
     </td>\par
\par
    </tr>`\par
\par
    \}\par
