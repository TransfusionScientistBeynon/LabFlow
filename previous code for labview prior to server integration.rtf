\par
// if there is no duplicate the incoming data stored in formData is set into storage and a sort function is called\par
function checkDuplicate()\{\par
\par
if (allHospitalNumbers.includes(currentHospitalNumber)) \{\par
    return false;\par
\par
\}else\{\par
        \par
        allRequests.push(formData); //formData is the parsed version of rcirequest\par
        localStorage.setItem("allRequests", JSON.stringify(allRequests))\par
