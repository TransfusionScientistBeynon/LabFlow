\par
    //VALIDATE REASON COLLECTS THE INPUT FROM REASON AND IF NO REASON GIVEN IT CREATES AN ERROR MESSAGE\par
function validateReason()\{\par
 reason = revertStatusReasonInput.value\par
\par
    if (!reason)\{\par
        valModalBox.hidden = false;\par
\par
    \}\par
    if (reason)\{\par
        valModalBox.hidden = true;\par
        \par
        updateAuditTrail();\par
        hideAuditTrail();\par
        \par
    \}\par
\par
    \par
\}\par
\par
function renderModalBox()\{\par
    if (overlay.hidden = true )\{\par
        overlay.hidden = false;\par
        modalBox.hidden = false;\par
        overlay.classList.add("overlayActive");\par
\par
    \}\par
\}\par
\par
function renderReasonBox()\{\par
    revertStatusPopUp.hidden = false;\par
\}\par
\par
function updateAuditTrail()\{\par
    console.log(overlay.dataset.id)\par
     let modalRequestId = overlay.dataset.id\par
     let reason = revertStatusReasonInput.value\par
\par
     const modalMatch = allRequests.find (function (item)\{\par
    return item.requestId === modalRequestId\par
\par
        \});\par
    console.log(modalMatch)\par
    console.log(modalRequestId)\par
\par
     modalMatch.status = requestState.requestSampleReceived\par
        modalMatch.auditTrail.push (\{\par
            status: requestState.requestSampleReceived,\par
            reason: reason\par
            \})\par
    localStorage.setItem("allRequests", JSON.stringify(allRequests))\par
\par
\}\par
\par
const valModalBox = document.getElementById("valModalBox")\par
function hideAuditTrail()\{\par
    \par
    overlay.hidden = true;\par
    modalBox.hidden = true;\par
    revertStatusPopUp.hidden = true;\par
    overlay.classList.remove("overlayActive");\par
    resetCheckboxes();\par
\par
\}\par
\par
function resetCheckboxes()\{\par
\par
    const auditCheckBoxes = document.querySelectorAll('input[type="checkbox"]')\par
\par
    auditCheckBoxes.forEach(function (checkbox)\{\par
        checkbox.checked = false\par
\par
    \});\par
\par
\}\par
