// This script works by getting the Rcirequest from the original page and parsing the information into an object stored in form data.\par
//I then created another storage method which stores all current requests or if there are no requests it makes an array.\par
// After this I created a function which pushes the previous request into the array thereby storing all current requests.\par
// At the send of the page the storage is set again and is stringified acting like a loop.\par
let tableDataHTML = ""\par
\par
 renderTable();\par
\par
\par
function renderTable()\{\par
    \par
    tableDataHTML = ""\par
    tableData.innerHTML = tableDataHTML;\par
\par
allRequests.sort(function (a,b) \{\par
       \par
a.DateRequested\par
a.TimeRequested\par
\par
b.DateRequested\par
b.TimeRequested\par
\par
a.dateTime = `$\{a.DateRequested\} $\{a.TimeRequested\}`\par
b.dateTime = `$\{b.DateRequested\} $\{b.TimeRequested\}`\par
\par
a.dateTimeObject = new Date(a.dateTime);\par
b.dateTimeObject = new Date(b.dateTime);\par
\par
return (a.dateTimeObject) - b.dateTimeObject; \par
\par
    \});\par
    allRequests.forEach (function (item) \{ ///This line states that for each item in the allRequests array add a line in the table\par
\par
